    "exception": [
      "blocked",
      "rework",
      "escalate_to_p10",
      "reopen",
      "awaiting_external",
      "owner_unclear",
      "tool_missing",
      "evidence_incomplete",
      "reroute_required",
      "reopen_required"
    ]
  },
  "runtime_profiles": {
    "default": "runtime6",
    "available": ["runtime6"],
    "principle": "6 resident roles + 4 on-demand specialists",
    "notes": [
      "P10 不再默认常驻，只在战略升级时介入",
      "Frontend/Console、Operations/Support、Documentation 改为按需唤起",
      "已移除旧角色字典层引用，采用硬删除口径"
    ]
  },
  "automation_policy": {
    "default_behavior": "internal_resolution_first",
    "action_protocol": "protocols/61_Automation_Orchestration_Protocol.md",
    "clearance_protocol": "protocols/62_Full_Issue_Discovery_Dispatch_and_Clearance_Protocol.md",
    "active_actions": [
      "create_issue_stub",
      "infer_owner_candidates",
      "infer_required_tools",
      "compute_owner_confidence",
      "compute_route_stability_score",
      "route_dry_run",
      "owner_self_resolve_attempt",
      "peer_role_consult",
      "split_subissues",
      "generate_exec_plan",
      "auto_reroute_on_new_truth",
      "high_risk_guard_gate",
      "auth_bypass_guard_gate",
      "runtime_stability_gate",
      "register_all_findings",
      "dispatch_all_registered_issues",
      "execute_by_owner",
      "validate_and_experience_by_issue",
      "rereview_all_open_issues",
      "register_new_findings_if_any",
      "continue_loop_until_open_issue_zero",
      "must_run_tool_gate",
      "autofill_exec_report",
      "generate_validation_bundle",
      "experience_replay",
      "compute_tool_coverage_score",
      "compute_evidence_completeness_score",
      "compute_reopen_risk_score",
      "auto_reopen_on_drift",
      "auto_docs_sink",
      "compute_closeout_readiness_score",
      "closeout_candidate_check"
    ],
    "thresholds": {
      "owner_confidence_min_for_direct_dispatch": 70,
      "route_stability_min_for_direct_dispatch": 65,
      "tool_coverage_min_before_review": 85,
      "evidence_completeness_min_before_review": 80,
      "closeout_readiness_min_before_done": 85,
      "reopen_risk_high": 60,
      "per_issue_type_overrides": {
        "auth": {
          "owner_confidence_min_for_direct_dispatch": 80
        },
        "docs": {
          "owner_confidence_min_for_direct_dispatch": 60
        }
      }
    },
    "hard_gates": {
      "require_issue_stub_before_dispatch": true,
      "require_score_gates_before_dispatch": true,
      "require_route_dry_run_when_owner_confidence_below_threshold": true,
      "require_tool_gate_before_dispatch": true,
      "require_high_risk_guard_before_sensitive_execution": true,
      "require_auth_bypass_guard_when_auth_scope_or_object_risk_present": true,
