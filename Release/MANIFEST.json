      "owner_unclear",
      "tool_missing",
      "evidence_incomplete",
      "reroute_required",
      "reopen_required"
    ]
  },
  "automation_policy": {
    "default_behavior": "internal_resolution_first",
    "action_protocol": "protocols/61_Automation_Orchestration_Protocol.md",
    "active_actions": [
      "create_issue_stub",
      "infer_owner_candidates",
      "infer_required_tools",
      "compute_owner_confidence",
      "compute_route_stability_score",
      "route_dry_run",
      "provisional_boundary_build",
      "owner_self_resolve_attempt",
      "peer_role_consult",
      "split_subissues",
      "fallback_to_p8_enhanced",
      "p9_reframe_and_redispatch",
      "must_run_tool_gate",
      "autofill_exec_report",
      "generate_validation_bundle",
      "experience_replay",
      "compute_tool_coverage_score",
      "compute_evidence_completeness_score",
      "tool_result_landing_check",
      "compute_reopen_risk_score",
      "auto_reopen_on_drift",
      "auto_docs_sink",
      "compute_closeout_readiness_score",
      "closeout_candidate_check"
    ],
    "active_action_batches": [
      "intake_normalization",
      "score_driven_routing",
      "self_resolution_and_internal_deliberation",
      "redispatch_and_fallback",
      "tool_gating",
      "execution_reporting",
      "validation_generation",
      "experience_replay_and_reopen",
      "docs_sink_and_closeout",
      "score_driven_decisioning"
    ],
    "thresholds": {
      "owner_confidence_min_for_direct_dispatch": 70,
      "route_stability_min_for_direct_dispatch": 65,
      "tool_coverage_min_before_review": 85,
      "evidence_completeness_min_before_review": 80,
      "closeout_readiness_min_before_done": 85,
      "reopen_risk_high": 60
    },
    "score_decision_rules": {
      "dispatch": {
        "require_owner_confidence_gte": 70,
        "require_route_stability_gte": 65,
        "otherwise": "route_dry_run_or_p9_reframe_and_redispatch"
      },
      "review": {
        "require_tool_coverage_gte": 85,
        "require_evidence_completeness_gte": 80,
        "otherwise": "tool_missing_or_evidence_incomplete"
      },
      "reopen": {
        "when_reopen_risk_gte": 60,
        "action": "auto_reopen_on_drift"
      },
      "done": {
        "require_closeout_readiness_gte": 85,
        "require_reopen_risk_lt": 60,
        "otherwise": "auto_reopen_on_drift_or_auto_docs_sink_then_recheck"
      }
    },
    "hard_gates": {
      "require_issue_stub_before_dispatch": true,
      "require_score_gates_before_dispatch": true,
      "require_route_dry_run_when_owner_confidence_below_threshold": true,
      "require_tool_gate_before_dispatch": true,
      "require_exec_report_before_review": true,
      "require_validation_bundle_before_review": true,
      "require_experience_replay_when_real_feedback_missing": true,
      "require_score_gates_before_review": true,
      "require_protocol_landing_before_review": true,
      "require_auto_reopen_on_drift": true,
      "require_auto_docs_sink_before_done": true,
      "require_score_gates_before_done": true,
      "require_closeout_candidate_check_before_done": true,
      "require_fallback_to_p8_enhanced_on_repeated_failure": true
    },
    "internal_escalation_chain": [
      "current_owner_self_resolution",
      "peer_role_consultation_or_split_dispatch",
      "p9_coordination_and_reframing",
      "p10_strategic_reroute",
      "user_escalation_only_if_internal_options_exhausted"
    ],
    "question_policy": "forbid_direct_user_confirmation_before_internal_exhaustion",
    "ask_user_only_when": [
      "irreversible_delete_or_overwrite",
      "production_data_destructive_change",
      "real_external_send_or_real_user_action_required",
      "requires_user_business_tradeoff_after_internal_options_exhausted",
      "legal_security_financial_boundary_exceeded",
      "strategy_conflict_after_p10_review"
    ],
    "soft_block_resolution": {
      "source_of_truth_partially_unclear": "use_current_batch_as_primary_source_and_log_assumption_then_continue",
      "boundary_not_precise_enough": "create_provisional_boundary_and_continue_non_destructive_work",
      "missing_real_experience_feedback": "generate_validation_bundle_then_experience_replay_before_closeout",
      "owner_unclear": "compute_owner_confidence_then_route_dry_run_then_p9_split_or_fallback_to_p8_pua_enhanced",
      "multi_owner_dependency": "owner_self_resolve_then_peer_role_consult_then_split_subissues_before_user_escalation",
      "repeated_execution_failure": "fallback_to_p8_enhanced_then_p9_reframe_and_redispatch",
      "review_or_experience_drift": "compute_reopen_risk_score_then_auto_reopen_on_drift_then_p9_reframe_and_redispatch",
      "closeout_not_ready": "compute_closeout_readiness_score_then_auto_docs_sink_or_reopen_then_recheck"
    }
  }
}